PROJECT_NAME=Crackmode
ENVIRONMENT=local

# ── Frontend ───────────────────────────────────────────────────────────────────
VITE_API_URL=/api/v1
DOMAIN=localhost
VITE_SUPABASE_URL=https://<your-project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<your-supabase-anon-key>

# ── Supabase (backend) ────────────────────────────────────────────────────────
SUPABASE_PROJECT_ID=<your-project-ref>
SUPABASE_JWT_SECRET=<your-supabase-jwt-secret>
SUPABASE_ANON_KEY=<your-supabase-anon-key>

# ── Database ───────────────────────────────────────────────────────────────────
# Local (Docker Compose)
POSTGRES_SERVER=db
POSTGRES_PORT=5432
POSTGRES_DB=railway
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme

# Production (Railway / hosted)
DATABASE_URL=postgresql://<user>:<password>@<host>:5432/<db>

# ── Admin seed (initial_data.py) ──────────────────────────────────────────────
FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_PASSWORD=changeme

# ── Gemini AI ─────────────────────────────────────────────────────────────────
GEMINI_API_KEY=<your-gemini-api-key>

# ── Green API (WhatsApp broadcasts) ───────────────────────────────────────────
GREEN_API_URL=https://<instance>.api.greenapi.com
GREEN_API_INSTANCE_ID=<your-instance-id>
GREEN_API_TOKEN=<your-green-api-token>
GREEN_API_GROUP_ID=<your-group-chat-id>@g.us
